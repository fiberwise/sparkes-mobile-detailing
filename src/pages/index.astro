---
import BaseLayout from '../layouts/BaseLayout.astro';
import BubbleField from '../components/BubbleField.astro';
---

<BaseLayout
  title="Sparkes Mobile Detailing — We come to you"
  description="Concours-grade hand wash and detail for high-end vehicles. Serving East Tennessee from Knoxville to Bristol. We come to you."
>
  <div class="page">
    <section class="hero">
      <BubbleField count={28} popChance={0.3} />

      <div class="hero-eyebrow">
        <span class="dot"></span>
        We come to you · Booking this week
      </div>

      <div class="lockup">
        <img src="/assets/sparkes-logo.png" class="sparkes-logo" alt="Sparkes Mobile Detailing" />
        <div class="lockup-sub">
          <span class="bar"></span>
          <span>Mobile Detailing</span>
          <span class="bar"></span>
        </div>
      </div>

      <p style="margin-top: 36px; max-width: 620px; color: var(--ink-soft); font-size: 18px; line-height: 1.6; text-wrap: pretty;">
        Concours-grade hand wash and detail for high-end vehicles —
        performed in your driveway, garage, or paddock. We bring the water,
        the wax, and the white gloves.
      </p>
      <p style="margin-top: 16px; max-width: 620px; color: var(--ink-soft); font-size: 18px; line-height: 1.6; text-wrap: pretty;">
        Serving East Tennessee from Knoxville to Bristol.
      </p>

      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Hey, come wash my car!</a>
        <a href="/about" class="btn btn-ghost">How it works →</a>
      </div>
    </section>

    <div class="road"></div>

    <section class="strip">
      <div>
        <h4>01 · Driveway service</h4>
        <p>Self-contained water + power. We work around your day, never the other way around.</p>
      </div>
      <div>
        <h4>02 · pH-neutral chemistry</h4>
        <p>Gyeon, Koch-Chemie, P&S — products chosen for paint, leather and chrome, not the price tag.</p>
      </div>
      <div>
        <h4>03 · Two-bucket, microfibre</h4>
        <p>Grit guards, plush mitts, dedicated wheels kit. Swirl marks are a choice, and not one we make.</p>
      </div>
      <div>
        <h4>04 · Insured &amp; obsessive</h4>
        <p>$2M public liability. Every panel inspected, every nook documented before we hand back the keys.</p>
      </div>
    </section>
  </div>
</BaseLayout>
