---
import BaseLayout from '../layouts/BaseLayout.astro';
import BubbleField from '../components/BubbleField.astro';
---

<BaseLayout
  title="Get a Quote — Sparkes Mobile Detailing"
  description="Tell us about your car. We'll text you back within a few hours to lock in a slot."
>

  <div class="page contact">
    <BubbleField count={14} popChance={0.2} />

    <div class="contact-head">
      <span class="kicker">Booking · We come to you</span>
      <h1>Hey, come wash<br/>my car!</h1>
      <p>
        Tell us about the car and where it lives. We'll text you back to lock
        in a slot — usually within a few hours during business hours.
      </p>
    </div>

    <div id="success-msg" class="form-card sent" style="display:none">
      <div class="sent-orb"></div>
      <h2>Message in the bucket.</h2>
      <p>We'll text you within a few hours to confirm a time and quote the job. In the meantime, give it a rinse so we have less work to do. (Kidding. Mostly.)</p>
      <p style="font-size:13px; color:var(--ink-mute); max-width:44ch; margin-top:4px;">
        A reminder: quoted pricing is an estimate. Final price may be adjusted based on the actual condition of your vehicle when we arrive.
      </p>
      <div style="display:flex; gap:12px; margin-top:8px; flex-wrap:wrap; justify-content:center;">
        <a href="/contact" class="btn btn-ghost">Send another</a>
        <a href="/" class="btn btn-primary">Back to home</a>
      </div>
    </div>

    <form
      id="quote-form"
      class="form-card"
      name="sparkes-quote"
      method="POST"
      action="/contact/?success=true"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="sparkes-quote" />
      <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>

      <div class="form-grid">

        <div class="field">
          <label for="f-name">Your name</label>
          <input id="f-name" name="name" type="text" required placeholder="John Doe" />
        </div>

        <div class="field">
          <label for="f-email">Email</label>
          <input id="f-email" name="email" type="email" required placeholder="johndoe@gmail.com" />
        </div>

        <div class="field">
          <label for="f-phone">Mobile</label>
          <input id="f-phone" name="phone" type="tel" required placeholder="(555) 010 0199" />
        </div>

        <div class="field">
          <label for="f-addr">Service address</label>
          <input id="f-addr" name="address" type="text" required placeholder="221B Driveway Lane" />
        </div>

        <div class="field">
          <label for="f-city">City</label>
          <input id="f-city" name="city" type="text" required placeholder="Anytown" />
        </div>

        <div class="field">
          <label for="f-state">State</label>
          <input id="f-state" name="state" type="text" required placeholder="ST" maxlength="2" style="text-transform:uppercase" />
        </div>

        <div class="field">
          <label for="f-car">Year, make &amp; model</label>
          <input id="f-car" name="car" type="text" required placeholder="2019 Porsche 911 GT3 Touring" />
        </div>

        <div class="field">
          <label for="f-color">Paint colour / finish</label>
          <input id="f-color" name="color" type="text" placeholder="Guards Red" />
        </div>

        <div class="field full coatings-field">
          <span class="coatings-label">Protective coatings on the car? <em>Check all that apply.</em></span>
          <div class="check-group">
            <label class="check-row" id="ppf-row">
              <input type="checkbox" name="has_ppf" value="yes" id="ppf-check" />
              <span class="check-box"></span>
              <span>Paint protection film (PPF)</span>
            </label>
            <label class="check-row check-sub" id="satin-row" style="display:none">
              <input type="checkbox" name="ppf_satin" value="yes" />
              <span class="check-box"></span>
              <span>Satin finish PPF</span>
            </label>
            <label class="check-row">
              <input type="checkbox" name="has_ceramic" value="yes" />
              <span class="check-box"></span>
              <span>Ceramic coating</span>
            </label>
          </div>
        </div>

        <div class="field">
          <label for="f-date">Preferred date</label>
          <input id="f-date" name="date" type="date" />
        </div>

        <div class="field">
          <label for="f-time">Time of day</label>
          <select id="f-time" name="time">
            <option value="morning">Morning (8 – 11)</option>
            <option value="midday">Midday (11 – 2)</option>
            <option value="afternoon">Afternoon (2 – 5)</option>
            <option value="flexible">Flexible — surprise me</option>
          </select>
        </div>

        <div class="pkg-row" role="radiogroup" aria-label="Package">

          <label class="pkg">
            <input type="radio" name="package" value="Maintenance Wash" checked />
            <div class="pkg-name">Maintenance Wash</div>
            <div class="pkg-price">$180<small> /visit</small></div>
            <div class="pkg-desc">Two-bucket hand wash, wheels, glass, interior wipe, tire dressing. ~2 hrs.</div>
          </label>

          <label class="pkg">
            <input type="radio" name="package" value="Full Detail" />
            <div class="pkg-name">Full Detail</div>
            <div class="pkg-price">$480<small> /visit</small></div>
            <div class="pkg-desc">Decon + clay + single-stage polish. Interior shampoo, leather feed, engine bay. ~6 hrs.</div>
          </label>

          <label class="pkg">
            <input type="radio" name="package" value="Coating Prep" />
            <div class="pkg-name">Coating Prep</div>
            <div class="pkg-price">$1,450<small> from</small></div>
            <div class="pkg-desc">Multi-stage paint correction + Gyeon or CQuartz application. 1–2 days.</div>
          </label>

        </div>

        <div class="field full">
          <label for="f-notes">Anything we should know?</label>
          <textarea id="f-notes" name="notes" placeholder="Bird strike on the hood, ceramic coating from last year, gated community gate code, garaged or curbside — the more the better."></textarea>
        </div>

        <div class="form-actions">
          <p class="fine">
            We respond by SMS within a few hours. No deposit needed for first-time bookings under $500.
            Cancellations are free up to 24 hrs before your slot.
            <br/><em>Pricing is an estimate — final price may be adjusted based on the actual condition of your vehicle when we arrive.</em>
          </p>
          <button class="submit" type="submit">
            Send the bucket
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
              <path d="M13 6l6 6-6 6"/>
            </svg>
          </button>
        </div>

      </div>
    </form>

    <div style="text-align:center; margin-top:28px;">
      <span class="bucket-tag"><span class="dot"></span>or call (865) 314-7405 · sparkesautodetailing@gmail.com</span>
    </div>

  </div>

  <script is:inline>
    document.getElementById('ppf-check').addEventListener('change', function() {
      document.getElementById('satin-row').style.display = this.checked ? 'flex' : 'none';
    });

    if (window.location.search.includes('success=true')) {
      var form = document.getElementById('quote-form');
      var msg  = document.getElementById('success-msg');
      if (form) form.style.display = 'none';
      if (msg)  msg.style.display  = 'flex';
    }
  </script>

  <style is:global>
    .pkg:has(input:checked) {
      border-color: rgba(34, 211, 238, 0.7);
      background: linear-gradient(180deg, rgba(34,211,238,.10), rgba(34,211,238,.03));
      box-shadow: 0 0 0 4px rgba(34,211,238,.10);
    }

    .coatings-field { gap: 12px }
    .coatings-label {
      font-size: 11px; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
      color: var(--ink-mute);
    }
    .coatings-label em { font-style: normal; font-weight: 400; text-transform: none; letter-spacing: 0; }
    .check-group { display: flex; flex-direction: column; gap: 10px }
    .check-row {
      display: flex; align-items: center; gap: 12px;
      cursor: pointer;
      font-size: 15px; color: var(--ink);
      padding: 10px 14px;
      border: 1px solid var(--line); border-radius: 12px;
      background: rgba(255,255,255,.02);
      transition: border .15s, background .15s;
      user-select: none;
    }
    .check-row:hover { border-color: rgba(34,211,238,.35); background: rgba(34,211,238,.04) }
    .check-row input[type="checkbox"] { position: absolute; opacity: 0; width: 0; height: 0 }
    .check-box {
      flex: 0 0 18px; height: 18px; border-radius: 5px;
      border: 1.5px solid var(--line);
      background: rgba(0,0,0,.25);
      display: flex; align-items: center; justify-content: center;
      transition: border .15s, background .15s;
    }
    .check-row input[type="checkbox"]:checked ~ .check-box {
      background: linear-gradient(135deg, #22d3ee, #3b82f6);
      border-color: transparent;
    }
    .check-row input[type="checkbox"]:checked ~ .check-box::after {
      content: "";
      width: 10px; height: 6px;
      border-left: 2px solid #fff; border-bottom: 2px solid #fff;
      transform: rotate(-45deg) translate(1px, -1px);
      display: block;
    }
    .check-row input[type="checkbox"]:checked ~ span:last-child { color: var(--cyan-bright) }
    .check-sub {
      margin-left: 28px;
      font-size: 13px;
      border-style: dashed;
    }
  </style>

</BaseLayout>
