---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>

  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />

  <!-- Open Graph / social preview -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://sparkesmobiledetailing.com" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://sparkesmobiledetailing.com/assets/sparkes-icon.png" />

  <!-- Twitter / iMessage card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://sparkesmobiledetailing.com/assets/sparkes-icon.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bagel+Fat+One&family=Anton&family=Manrope:wght@300;400;500;600;700;800&family=Archivo+Black&display=swap" rel="stylesheet" />

  <script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>

  <style>
    :root{
      --bg-0:#03060d;
      --bg-1:#0a1426;
      --bg-2:#102243;
      --ink:#eaf6ff;
      --ink-soft:#a9c1da;
      --ink-mute:#6f86a3;
      --cyan:#22d3ee;
      --cyan-bright:#5eead4;
      --blue:#3b82f6;
      --blue-deep:#1d4ed8;
      --magenta:#c026d3;
      --magenta-soft:#e879f9;
      --gold:#fbbf24;
      --line:rgba(255,255,255,.08);
      --card:rgba(255,255,255,.04);
      --card-hi:rgba(255,255,255,.07);
      --shadow-lg:0 30px 80px -20px rgba(0,0,0,.7), 0 8px 24px -8px rgba(34,211,238,.18);
    }

    *{box-sizing:border-box}
    html,body{margin:0;padding:0;height:100%;background:var(--bg-0)}
    body{
      font-family:"Manrope","Helvetica Neue",Helvetica,Arial,sans-serif;
      color:var(--ink);
      background:
        radial-gradient(1200px 700px at 80% -10%, rgba(34,211,238,.10), transparent 60%),
        radial-gradient(900px 600px at 10% 110%, rgba(192,38,211,.10), transparent 60%),
        linear-gradient(180deg, var(--bg-1) 0%, var(--bg-0) 90%);
      background-attachment:fixed;
      overflow-x:hidden;
      min-height:100vh;
      text-rendering:optimizeLegibility;
      -webkit-font-smoothing:antialiased;
    }

    /* subtle dot grid — matches the napkin sketch backdrop */
    body::before{
      content:"";
      position:fixed; inset:0; pointer-events:none; z-index:0;
      background-image: radial-gradient(rgba(255,255,255,.05) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: radial-gradient(ellipse at center, black 50%, transparent 95%);
    }

    #root{position:relative; z-index:1}

    /* ───────── NAV ───────── */
    .nav{
      position:sticky; top:0; z-index:50;
      display:flex; align-items:center; justify-content:space-between;
      padding:18px 32px;
      backdrop-filter: blur(14px) saturate(140%);
      -webkit-backdrop-filter: blur(14px) saturate(140%);
      background:linear-gradient(180deg, rgba(3,6,13,.7), rgba(3,6,13,.35));
      border-bottom:1px solid var(--line);
    }
    .nav-mark{
      display:flex; align-items:center; gap:12px; cursor:pointer; user-select:none;
    }
    .nav-mark img{
      height:42px; width:auto; display:block;
      filter: drop-shadow(0 0 18px rgba(34,211,238,.35));
      user-select:none; -webkit-user-drag:none;
    }
    .nav-mark .nm-sub{
      font-family:"Anton",sans-serif; font-weight:400;
      font-size:11px; letter-spacing:.32em;
      color:var(--ink-soft);
    }
    .nav-links{ display:flex; gap:6px; align-items:center }
    .nav-link{
      appearance:none; border:0; background:transparent;
      font:inherit; color:var(--ink-soft);
      font-size:13px; font-weight:500; letter-spacing:.06em; text-transform:uppercase;
      padding:10px 14px; border-radius:999px; cursor:pointer;
      transition: color .2s ease, background .2s ease;
      text-decoration:none;
    }
    .nav-link:hover{ color:var(--ink); background:rgba(255,255,255,.04) }
    .nav-link.is-active{ color:var(--ink); background:rgba(34,211,238,.10) }
    .nav-cta{
      margin-left:8px;
      display:inline-flex; align-items:center; gap:8px;
      padding:10px 16px; border-radius:999px;
      background:linear-gradient(135deg, #22d3ee, #3b82f6 60%, #c026d3);
      color:#fff; font-weight:700; font-size:12px; letter-spacing:.08em; text-transform:uppercase;
      border:0; cursor:pointer;
      box-shadow: 0 6px 24px -8px rgba(34,211,238,.55), inset 0 1px 0 rgba(255,255,255,.4);
      transition: transform .15s ease, box-shadow .15s ease;
      text-decoration:none;
    }
    .nav-cta:hover{ transform: translateY(-1px); box-shadow: 0 10px 30px -8px rgba(34,211,238,.7), inset 0 1px 0 rgba(255,255,255,.5) }

    /* ───────── PAGE TRANSITIONS ───────── */
    .page{ animation: pageIn .55s cubic-bezier(.2,.8,.2,1) both }
    @keyframes pageIn{ from{opacity:0; transform:translateY(12px)} to{opacity:1; transform:none} }

    /* ───────── LOGO LOCKUP ───────── */
    .lockup{
      position:relative;
      display:inline-flex; flex-direction:column; align-items:center; gap:10px;
      isolation:isolate;
    }

    .sparkes-logo{
      width: clamp(280px, 62vw, 760px);
      height:auto; display:block;
      user-select:none; -webkit-user-drag:none;
      filter:
        drop-shadow(0 18px 30px rgba(34,211,238,.35))
        drop-shadow(0 30px 60px rgba(192,38,211,.25));
      animation: logoFloat 6s ease-in-out infinite;
    }
    @keyframes logoFloat{
      50%{ transform: translateY(-6px) rotate(-.4deg) }
    }

    .lockup{ margin-top:-30px }
    .lockup-sub{
      display:flex; align-items:center; gap:14px;
      margin-top:-10px;
      font-family:"Anton",sans-serif;
      font-size: clamp(18px, 2.6vw, 36px);
      letter-spacing: clamp(.18em, .5vw, .36em);
      color:var(--ink);
      text-transform:uppercase;
    }
    .lockup-sub .bar{ width:36px; height:2px; background:linear-gradient(90deg, transparent, var(--cyan), transparent) }

    .tagline{
      color:var(--cyan-bright);
      font-family:"Manrope",sans-serif;
      font-weight:600; letter-spacing:.18em; text-transform:uppercase;
      font-size:12px;
    }

    /* ───────── BUBBLES ───────── */
    .bubble-field{
      position:absolute; inset:-10% -5% -5% -5%;
      pointer-events:none; z-index:-1;
      overflow:hidden;
    }
    .bubble{
      position:absolute; bottom:-40px;
      border-radius:50%;
      background:
        radial-gradient(circle at 30% 28%, rgba(255,255,255,.95) 0%, rgba(186,230,253,.75) 18%, rgba(56,189,248,.35) 50%, rgba(56,189,248,.05) 80%),
        linear-gradient(180deg, rgba(255,255,255,.2), rgba(255,255,255,0));
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,.45),
        inset -4px -6px 12px rgba(2,132,199,.35),
        0 0 18px rgba(34,211,238,.25);
      opacity:0;
      will-change: transform, opacity;
      animation: rise var(--dur,12s) cubic-bezier(.25,.55,.4,1) infinite;
      animation-delay: var(--delay,0s);
      filter: blur(.2px);
    }
    .bubble.pop{ animation-name: rise-pop }
    @keyframes rise{
      0%   { transform: translate3d(0, 0, 0) scale(.6); opacity:0 }
      8%   { opacity:.85 }
      50%  { transform: translate3d(var(--drift,8px), -45vh, 0) scale(1) }
      92%  { opacity:.85 }
      100% { transform: translate3d(calc(var(--drift,8px) * -1.4), -95vh, 0) scale(.85); opacity:0 }
    }
    @keyframes rise-pop{
      0%   { transform: translate3d(0, 0, 0) scale(.4); opacity:0 }
      10%  { opacity:.9 }
      85%  { transform: translate3d(var(--drift,12px), -75vh, 0) scale(1.08); opacity:.9 }
      95%  { transform: translate3d(var(--drift,12px), -82vh, 0) scale(1.6); opacity:0 }
      100% { transform: translate3d(var(--drift,12px), -82vh, 0) scale(0); opacity:0 }
    }

    /* ───────── HERO LAYOUT ───────── */
    .hero{
      position:relative;
      min-height: calc(100vh - 80px);
      display:flex; flex-direction:column;
      align-items:center; justify-content:center;
      padding: 60px 32px 140px;
      text-align:center;
      overflow:hidden;
    }
    .hero-eyebrow{
      display:inline-flex; align-items:center; gap:14px;
      padding:14px 22px; border-radius:999px;
      background: rgba(34,211,238,.10);
      border:1px solid rgba(34,211,238,.35);
      color:var(--cyan-bright);
      font-size:15px; font-weight:700; letter-spacing:.22em; text-transform:uppercase;
      margin-bottom:32px;
      box-shadow: 0 8px 30px -10px rgba(34,211,238,.35);
    }
    .hero-eyebrow .dot{
      width:9px; height:9px; border-radius:50%;
      background:var(--cyan); box-shadow:0 0 14px var(--cyan);
      animation: pulse 1.6s ease-in-out infinite;
    }
    @media (max-width:520px){
      .hero-eyebrow{ font-size:12px; padding:11px 16px; gap:10px }
    }
    @keyframes pulse{ 50%{ transform:scale(1.4); opacity:.6 } }

    .hero-actions{
      display:flex; gap:14px; margin-top:48px; flex-wrap:wrap; justify-content:center;
    }
    .btn{
      appearance:none; border:0; cursor:pointer; font:inherit;
      padding:16px 28px; border-radius:999px;
      font-weight:700; font-size:13px; letter-spacing:.12em; text-transform:uppercase;
      transition: transform .15s ease, box-shadow .15s ease, background .2s ease;
      text-decoration:none;
    }
    .btn-primary{
      color:#03060d;
      background:linear-gradient(135deg, #5eead4, #22d3ee 35%, #3b82f6 100%);
      box-shadow:
        0 12px 40px -8px rgba(34,211,238,.55),
        inset 0 1px 0 rgba(255,255,255,.55),
        inset 0 -2px 0 rgba(2,132,199,.4);
    }
    .btn-primary:hover{ transform: translateY(-2px); box-shadow: 0 18px 50px -8px rgba(34,211,238,.7), inset 0 1px 0 rgba(255,255,255,.6) }
    .btn-ghost{
      color:var(--ink);
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.14);
    }
    .btn-ghost:hover{ background:rgba(255,255,255,.08); border-color:rgba(255,255,255,.22) }

    /* ───────── FEATURE STRIP ───────── */
    .strip{
      display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
      margin: 0 auto;
      max-width:1100px;
      background:var(--line);
      border-top:1px solid var(--line); border-bottom:1px solid var(--line);
    }
    .strip > div{
      background: var(--bg-0);
      padding: 36px 28px; text-align:left;
    }
    .strip h4{
      margin:0 0 12px; font-family:"Anton"; letter-spacing:.16em; text-transform:uppercase;
      font-size:18px; color:var(--cyan);
    }
    .strip p{ margin:0; font-size:16px; line-height:1.6; color:var(--ink) }
    @media (max-width:780px){ .strip{ grid-template-columns:repeat(2,1fr) } }

    /* ───────── SERVICES ───────── */
    .services{ padding: 60px 32px 120px; max-width:1200px; margin:0 auto; position:relative }
    .services-head{ text-align:center; margin-bottom:64px }
    .services-head .kicker{
      color:var(--cyan-bright); font-weight:600; letter-spacing:.22em; text-transform:uppercase; font-size:12px;
    }
    .services-head h1{
      font-family:"Anton",sans-serif;
      font-size: clamp(56px, 9vw, 130px);
      letter-spacing:.04em; text-transform:uppercase;
      margin:14px 0 16px; line-height:.92;
    }
    .services-head h1 em{
      font-style:normal;
      background:linear-gradient(180deg,#7dd3fc,#0ea5e9);
      -webkit-background-clip:text; background-clip:text; color:transparent;
    }
    .services-head p{ color:var(--ink-soft); max-width:60ch; margin:0 auto; font-size:17px; line-height:1.6 }

    .tiers{
      display:grid; grid-template-columns: repeat(3, 1fr); gap:20px;
    }
    @media (max-width:980px){ .tiers{ grid-template-columns:1fr } }
    .tier{
      position:relative;
      background:linear-gradient(180deg, rgba(16,34,67,.55), rgba(10,20,38,.55));
      border:1px solid var(--line);
      border-radius:24px;
      padding:32px 28px 28px;
      display:flex; flex-direction:column;
      backdrop-filter: blur(8px);
      transition: transform .25s ease, border .2s ease, box-shadow .25s ease;
    }
    .tier:hover{ transform: translateY(-4px); border-color: rgba(34,211,238,.4); box-shadow: 0 24px 60px -20px rgba(34,211,238,.35) }
    .tier.feat{
      background:linear-gradient(180deg, rgba(34,211,238,.10), rgba(10,20,38,.7));
      border-color: rgba(34,211,238,.5);
      box-shadow: 0 24px 60px -20px rgba(34,211,238,.35), inset 0 1px 0 rgba(255,255,255,.05);
    }
    .tier-flag{
      position:absolute; top:-12px; left:50%; transform:translateX(-50%);
      background:linear-gradient(135deg,#5eead4,#22d3ee 50%,#c026d3);
      color:#03060d; font-weight:800; font-size:10px; letter-spacing:.22em; text-transform:uppercase;
      padding:6px 12px; border-radius:999px;
      box-shadow: 0 8px 24px -4px rgba(34,211,238,.5);
    }
    .tier-name{
      font-family:"Anton"; letter-spacing:.14em; text-transform:uppercase; font-size:22px; color:var(--ink); margin:0;
    }
    .tier-tag{
      color:var(--cyan-bright); font-size:12px; font-weight:600; letter-spacing:.18em; text-transform:uppercase;
      margin-top:6px;
    }
    .tier-price{
      margin:24px 0 18px;
      display:flex; align-items:baseline; gap:8px;
      font-family:"Archivo Black", "Anton", sans-serif;
    }
    .tier-price .amt{ font-size:54px; line-height:1; color:var(--ink); font-feature-settings:"tnum" }
    .tier-price .unit{ color:var(--ink-mute); font-size:13px; font-weight:500; letter-spacing:.08em }
    .tier-price .from{ font-size:12px; color:var(--ink-mute); font-weight:500; letter-spacing:.18em; text-transform:uppercase; margin-right:4px; align-self:flex-start; transform:translateY(8px) }
    .tier-desc{ color:var(--ink-soft); font-size:14px; line-height:1.55; margin:0 0 22px }
    .tier ul{
      list-style:none; padding:0; margin:0 0 28px;
      display:flex; flex-direction:column; gap:10px;
      border-top:1px dashed var(--line); padding-top:20px;
    }
    .tier li{
      display:flex; gap:12px; align-items:flex-start;
      font-size:14px; line-height:1.5; color:var(--ink);
    }
    .tier li::before{
      content:""; flex:0 0 16px; height:16px; margin-top:2px;
      border-radius:50%;
      background: radial-gradient(circle at 30% 30%, #fff, #22d3ee 55%, #075985 100%);
      box-shadow: 0 0 8px rgba(34,211,238,.55);
    }
    .tier li.no::before{
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.2), rgba(255,255,255,.04) 60%, transparent);
      box-shadow:none;
    }
    .tier li.no{ color:var(--ink-mute); text-decoration: line-through; text-decoration-color: rgba(255,255,255,.25) }
    .tier-meta{
      margin-top:auto;
      display:flex; align-items:center; justify-content:space-between;
      color:var(--ink-mute); font-size:11px; letter-spacing:.18em; text-transform:uppercase;
      padding-top:18px; border-top:1px solid var(--line); margin-bottom:18px;
    }
    .tier-cta{
      appearance:none; border:0; cursor:pointer; font:inherit;
      width:100%; padding:14px 18px; border-radius:14px;
      font-weight:700; font-size:12px; letter-spacing:.18em; text-transform:uppercase;
      color:var(--ink);
      background:rgba(255,255,255,.05);
      border:1px solid var(--line);
      transition: background .15s ease, border .15s ease, transform .15s ease;
    }
    .tier-cta:hover{ background:rgba(34,211,238,.10); border-color: rgba(34,211,238,.5); transform: translateY(-1px) }
    .tier.feat .tier-cta{
      color:#03060d;
      background:linear-gradient(135deg,#5eead4,#22d3ee 50%,#3b82f6);
      border-color: transparent;
      box-shadow: 0 12px 32px -8px rgba(34,211,238,.5), inset 0 1px 0 rgba(255,255,255,.5);
    }
    .tier.feat .tier-cta:hover{ box-shadow: 0 18px 40px -8px rgba(34,211,238,.6), inset 0 1px 0 rgba(255,255,255,.6) }

    /* SERVICES — group sections (Mobile / Paint / Ceramic) */
    .svc-group{ margin-top:64px }
    .svc-group:first-of-type{ margin-top:24px }
    .svc-disclaimer{
      text-align:center; color:var(--ink-mute);
      font-size:13px; letter-spacing:.06em;
      margin: 56px 0 28px;
    }
    .svc-footer-cta{
      display:flex; gap:14px; justify-content:center; align-items:center; flex-wrap:wrap;
      margin-bottom: 24px;
    }
    .svc-footer-cta .btn-ghost{ display:inline-flex; align-items:center }
    .section-h{
      display:flex; align-items:baseline; justify-content:space-between; gap:16px;
      margin-bottom:24px; padding-bottom:18px; border-bottom:1px solid var(--line);
    }
    .section-h h2{
      font-family:"Anton"; letter-spacing:.06em; text-transform:uppercase;
      font-size: clamp(28px, 4vw, 44px); margin:0;
    }
    .section-h .lead{ color:var(--ink-mute); font-size:13px; letter-spacing:.18em; text-transform:uppercase }
    .addons{
      display:grid; grid-template-columns:repeat(3,1fr); gap:14px;
    }
    @media (max-width:880px){ .addons{ grid-template-columns:1fr } }
    .addon{
      display:flex; align-items:flex-start; gap:14px;
      padding:18px 20px;
      border:1px solid var(--line); border-radius:16px;
      background: rgba(255,255,255,.02);
      transition: border .15s ease, background .15s ease;
    }
    .addon:hover{ border-color: rgba(34,211,238,.35); background: rgba(34,211,238,.04) }
    .addon-num{
      flex:0 0 auto;
      font-family:"Archivo Black"; font-size:22px;
      color: var(--cyan-bright);
      width:44px; line-height:1; padding-top:2px;
      font-feature-settings:"tnum";
    }
    .addon-body h5{ margin:0 0 4px; font-family:"Anton"; letter-spacing:.12em; text-transform:uppercase; font-size:14px; color:var(--ink) }
    .addon-body p{ margin:0; color:var(--ink-soft); font-size:13px; line-height:1.5 }
    .addon-price{
      margin-left:auto; flex:0 0 auto;
      color:var(--cyan-bright); font-weight:700; font-feature-settings:"tnum";
      font-size:15px; padding-top:2px;
    }

    /* FAQ on services */
    .faq-wrap{ margin-top:96px; max-width:880px; margin-left:auto; margin-right:auto }
    .faq{
      border-bottom:1px solid var(--line);
      padding: 22px 0;
    }
    .faq summary{
      cursor:pointer; list-style:none;
      display:flex; align-items:center; justify-content:space-between; gap:16px;
      font-family:"Anton"; letter-spacing:.08em; text-transform:uppercase;
      font-size:18px; color:var(--ink);
    }
    .faq summary::-webkit-details-marker{ display:none }
    .faq summary::after{
      content:"+"; font-family:"Manrope"; font-weight:300; font-size:24px;
      color:var(--cyan); transition: transform .2s ease;
    }
    .faq[open] summary::after{ transform: rotate(45deg) }
    .faq p{ margin: 14px 0 0; color:var(--ink-soft); font-size:15px; line-height:1.65; max-width:64ch }

    /* Final CTA banner */
    .cta-banner{
      margin-top:96px; padding: 56px 40px;
      border-radius:28px; position:relative; overflow:hidden;
      background:
        radial-gradient(600px 300px at 80% 20%, rgba(34,211,238,.20), transparent 70%),
        radial-gradient(500px 280px at 10% 90%, rgba(192,38,211,.18), transparent 70%),
        linear-gradient(180deg, rgba(16,34,67,.7), rgba(10,20,38,.7));
      border:1px solid var(--line);
      display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap;
    }
    .cta-banner h3{
      font-family:"Anton"; letter-spacing:.06em; text-transform:uppercase;
      font-size: clamp(28px, 4.5vw, 48px); margin:0; line-height:1;
    }
    .cta-banner p{ margin:10px 0 0; color:var(--ink-soft); font-size:15px; max-width:46ch }
    .about{
      padding: 80px 32px 140px;
      max-width:1100px; margin:0 auto;
    }
    .about h1{
      font-family:"Anton",sans-serif;
      font-size: clamp(48px, 8vw, 110px);
      letter-spacing:.06em; text-transform:uppercase;
      margin:0 0 24px;
      line-height:.95;
    }
    .about h1 em{
      font-style:normal;
      background:linear-gradient(180deg, #7dd3fc, #0ea5e9);
      -webkit-background-clip:text; background-clip:text; color:transparent;
    }
    .about-lede{
      font-size: clamp(18px, 2vw, 22px);
      color:var(--ink-soft); max-width:65ch;
      line-height:1.55;
      margin:0 0 56px;
      text-wrap:pretty;
    }
    .grid-2{
      display:grid; grid-template-columns: 1.1fr 1fr; gap:48px; align-items:start;
    }
    @media (max-width:880px){ .grid-2{ grid-template-columns:1fr; gap:40px } }
    .about-block h3{
      font-family:"Anton"; letter-spacing:.18em; text-transform:uppercase;
      font-size:14px; color:var(--cyan); margin:0 0 14px;
    }
    .about-block p{ margin:0 0 14px; line-height:1.65; color:var(--ink-soft); font-size:15px }

    .specs{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:24px;
      padding:28px;
      backdrop-filter: blur(8px);
    }
    .specs ul{ margin:0; padding:0; list-style:none; display:flex; flex-direction:column; gap:14px }
    .specs li{ display:flex; gap:14px; align-items:flex-start; font-size:14px; color:var(--ink-soft); line-height:1.5 }
    .specs li b{ color:var(--ink); font-weight:600 }
    .specs li::before{
      content:""; flex:0 0 8px; height:8px; border-radius:50%;
      margin-top:7px;
      background:radial-gradient(circle at 30% 30%, #fff, #22d3ee 60%, #075985);
      box-shadow: 0 0 8px rgba(34,211,238,.6);
    }

    .marquee{
      margin: 80px -32px 0;
      overflow:hidden;
      border-top:1px solid var(--line);
      border-bottom:1px solid var(--line);
      padding: 22px 0;
      background:linear-gradient(180deg, rgba(34,211,238,.04), transparent);
    }
    .marquee-track{
      display:flex; gap:48px; white-space:nowrap;
      animation: marq 38s linear infinite;
      font-family:"Anton"; font-size:28px; letter-spacing:.18em; text-transform:uppercase;
      color:var(--ink);
    }
    .marquee-track span{ display:inline-flex; align-items:center; gap:48px }
    .marquee-track i{
      font-style:normal; color:var(--cyan); font-size:14px;
      display:inline-block; transform: translateY(-3px);
    }
    @keyframes marq{ to{ transform: translateX(-50%) } }

    /* ───────── CONTACT ───────── */
    .contact{
      padding: 60px 32px 140px;
      max-width:1100px; margin:0 auto;
    }
    .contact-head{
      text-align:center; margin-bottom:48px;
    }
    .contact-head .kicker{
      color:var(--magenta-soft); font-weight:600; letter-spacing:.22em; text-transform:uppercase; font-size:12px;
    }
    .contact-head h1{
      font-family:"Bagel Fat One",cursive;
      font-size: clamp(48px, 8vw, 96px);
      line-height:1; margin: 14px 0 8px;
      transform: skew(-6deg) rotate(-1deg);
      background:linear-gradient(180deg, #bae6fd, #22d3ee 50%, #0ea5e9);
      -webkit-background-clip:text; background-clip:text; color:transparent;
      -webkit-text-stroke:2px #0a1426;
      filter: drop-shadow(3px 4px 0 #c026d3) drop-shadow(0 0 24px rgba(34,211,238,.35));
    }
    .contact-head p{ color:var(--ink-soft); margin:18px auto 0; max-width:560px; font-size:16px; line-height:1.6 }

    .form-card{
      position:relative;
      background:linear-gradient(180deg, rgba(16,34,67,.7), rgba(10,20,38,.65));
      border:1px solid var(--line);
      border-radius:28px;
      padding:40px;
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(10px);
    }
    .form-card::before{
      content:""; position:absolute; inset:-1px; border-radius:28px;
      padding:1px;
      background: linear-gradient(135deg, rgba(34,211,238,.5), transparent 30%, transparent 70%, rgba(192,38,211,.5));
      -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
      -webkit-mask-composite: xor; mask-composite: exclude;
      pointer-events:none;
    }
    .form-grid{
      display:grid; grid-template-columns:1fr 1fr; gap:18px 22px;
    }
    @media (max-width:680px){ .form-grid{ grid-template-columns:1fr } }
    .field{ display:flex; flex-direction:column; gap:8px; min-width:0 }
    .field.full{ grid-column:1/-1 }
    .field label{
      font-size:11px; font-weight:600; letter-spacing:.18em; text-transform:uppercase;
      color:var(--ink-mute);
    }
    .field input, .field select, .field textarea{
      appearance:none; background:rgba(0,0,0,.25);
      border:1px solid var(--line);
      color:var(--ink);
      font:inherit; font-size:15px;
      padding:14px 16px; border-radius:14px;
      transition:border .15s ease, background .15s ease, box-shadow .15s ease;
      width:100%;
      font-family:inherit;
    }
    .field textarea{ min-height:120px; resize:vertical; line-height:1.5 }
    .field input:focus, .field select:focus, .field textarea:focus{
      outline:none; border-color: rgba(34,211,238,.6);
      background:rgba(0,0,0,.35);
      box-shadow: 0 0 0 4px rgba(34,211,238,.12);
    }
    .field select{
      background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 7'><path d='M1 1l5 5 5-5' stroke='%2322d3ee' stroke-width='1.5' fill='none' stroke-linecap='round'/></svg>");
      background-repeat:no-repeat; background-position: right 16px center; background-size:12px;
      padding-right:38px;
    }
    .field select option{ background:var(--bg-1); color:var(--ink) }

    .pkg-row{
      display:grid; grid-template-columns: repeat(3, 1fr); gap:12px;
      grid-column:1/-1;
    }
    @media (max-width:640px){ .pkg-row{ grid-template-columns:1fr } }
    .pkg{
      position:relative;
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      border-radius:18px;
      padding:18px;
      cursor:pointer;
      transition: border .15s ease, transform .15s ease, background .15s ease;
    }
    .pkg:hover{ transform:translateY(-2px); background:rgba(255,255,255,.05) }
    .pkg input{ position:absolute; opacity:0; pointer-events:none }
    .pkg-name{ font-family:"Anton"; letter-spacing:.16em; text-transform:uppercase; font-size:14px; color:var(--ink) }
    .pkg-price{ margin-top:4px; font-size:24px; font-weight:700; color:var(--cyan-bright); font-feature-settings:"tnum" }
    .pkg-price small{ font-size:12px; color:var(--ink-mute); font-weight:500; letter-spacing:.06em }
    .pkg-desc{ margin-top:8px; font-size:12px; color:var(--ink-soft); line-height:1.5 }
    .pkg.is-on{
      border-color: rgba(34,211,238,.7);
      background:linear-gradient(180deg, rgba(34,211,238,.10), rgba(34,211,238,.03));
      box-shadow: 0 0 0 4px rgba(34,211,238,.10);
    }

    .form-actions{
      grid-column:1/-1;
      display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;
      padding-top:14px; border-top:1px dashed var(--line);
      margin-top:8px;
    }
    .fine{ color:var(--ink-mute); font-size:12px; line-height:1.5; max-width:46ch }

    .submit{
      appearance:none; border:0; cursor:pointer; font:inherit;
      padding:18px 30px; border-radius:999px;
      color:#03060d; font-weight:800; font-size:13px; letter-spacing:.18em; text-transform:uppercase;
      background:linear-gradient(135deg, #5eead4, #22d3ee 40%, #c026d3 130%);
      box-shadow: 0 14px 40px -8px rgba(34,211,238,.55), inset 0 1px 0 rgba(255,255,255,.55);
      transition: transform .15s ease, box-shadow .15s ease;
      display:inline-flex; align-items:center; gap:10px;
      white-space:nowrap;
    }
    .submit:hover{ transform: translateY(-2px); box-shadow: 0 20px 60px -8px rgba(34,211,238,.7), inset 0 1px 0 rgba(255,255,255,.6) }
    .submit:disabled{ opacity:.6; cursor:not-allowed; transform:none }
    .submit svg{ width:16px; height:16px }

    /* Success state */
    .sent{
      text-align:center; padding:60px 24px;
      display:flex; flex-direction:column; align-items:center; gap:18px;
    }
    .sent-orb{
      width:96px; height:96px; border-radius:50%;
      background: radial-gradient(circle at 30% 28%, #fff, #22d3ee 50%, #0ea5e9 90%);
      box-shadow: 0 0 60px rgba(34,211,238,.55), inset 0 0 0 2px rgba(255,255,255,.5);
      animation: bob 3s ease-in-out infinite;
    }
    @keyframes bob{ 50%{ transform: translateY(-8px) } }
    .sent h2{ font-family:"Anton"; letter-spacing:.12em; text-transform:uppercase; font-size:30px; margin:0 }
    .sent p{ color:var(--ink-soft); margin:0; max-width:46ch; line-height:1.6 }

    /* ───────── FOOTER ───────── */
    footer.site-footer{ padding-block: 56px 36px }

    /* ───────── ROAD STRIP (decorative) ───────── */
    .road{
      position:relative;
      height:6px;
      background:linear-gradient(90deg, transparent, rgba(34,211,238,.5) 20%, rgba(192,38,211,.5) 80%, transparent);
      overflow:hidden;
      margin: 0;
    }
    .road::before{
      content:""; position:absolute; inset:2px 0; height:2px;
      background:repeating-linear-gradient(90deg, #fff 0 24px, transparent 24px 56px);
      opacity:.55;
      animation: dash 3.6s linear infinite;
    }
    @keyframes dash{ to{ background-position-x: -56px } }

    /* nav contact actions */
    .nav-contact{
      display:flex; gap:8px; align-items:center; margin-left:14px; padding-left:14px;
      border-left:1px solid var(--line);
    }
    .nav-contact a{
      display:inline-flex; align-items:center; gap:8px;
      padding:9px 14px; border-radius:999px;
      text-decoration:none;
      font-size:12px; font-weight:600; letter-spacing:.06em;
      color:var(--ink); border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      transition: border .15s ease, background .15s ease, color .15s ease;
    }
    .nav-contact a.call{ border-color: rgba(34,211,238,.4); color: var(--cyan-bright) }
    .nav-contact a.call:hover{ background:rgba(34,211,238,.10); border-color: rgba(34,211,238,.7) }
    .nav-contact a.mail{ border-color: rgba(192,38,211,.4); color: var(--magenta-soft) }
    .nav-contact a.mail:hover{ background:rgba(192,38,211,.10); border-color: rgba(192,38,211,.7) }
    .nav-contact svg{ width:14px; height:14px }
    @media (max-width:880px){ .nav-contact{ display:none } }

    /* Footer */
    .site-footer{
      border-top:1px solid var(--line);
      padding: 56px 32px 36px;
      margin-top: 40px;
      background: linear-gradient(180deg, rgba(10,20,38,.45), transparent);
    }
    .footer-grid{
      max-width:1200px; margin:0 auto;
      display:grid; grid-template-columns: 1.2fr 1fr 1.2fr; gap:48px;
    }
    @media (max-width:880px){ .footer-grid{ grid-template-columns:1fr; gap:32px } }
    .footer-brand img{ height:64px; width:auto; display:block; margin-bottom:14px; -webkit-user-drag:none }
    .footer-brand p{ margin:0; color:var(--ink-soft); font-size:14px; line-height:1.6; max-width:36ch }
    .footer-h{
      font-family:"Anton"; letter-spacing:.16em; text-transform:uppercase;
      font-size:13px; color:var(--cyan); margin:0 0 16px;
    }
    .footer-links{ list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px }
    .footer-links button, .footer-links a{
      appearance:none; border:0; background:transparent; padding:0;
      color:var(--ink-soft); font:inherit; text-align:left; cursor:pointer;
      text-decoration:none; font-size:14px;
      transition: color .15s ease;
    }
    .footer-links button:hover, .footer-links a:hover{ color:var(--cyan-bright) }
    .footer-contact{ display:flex; flex-direction:column; gap:14px }
    .footer-contact a, .footer-contact span{
      display:flex; align-items:center; gap:12px;
      color:var(--ink); text-decoration:none; font-size:14px;
      transition: color .15s ease;
    }
    .footer-contact a:hover{ color:var(--cyan-bright) }
    .footer-contact svg{ width:18px; height:18px; color:var(--cyan); flex:0 0 18px }
    .footer-base{
      max-width:1200px; margin: 40px auto 0;
      padding-top: 24px; border-top:1px solid var(--line);
      display:flex; align-items:center; justify-content:space-between; gap:14px;
      color:var(--ink-mute); font-size:12px; flex-wrap:wrap;
    }
    .footer-base .heart{ color:var(--magenta-soft) }
    .bucket-tag{
      display:inline-flex; align-items:center; gap:10px;
      padding:6px 12px; border-radius:999px;
      background:rgba(255,255,255,.04); border:1px solid var(--line);
      font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--ink-soft);
    }
    .bucket-tag .dot{
      width:6px; height:6px; border-radius:50%; background:var(--cyan); box-shadow:0 0 10px var(--cyan);
    }
  </style>
</head>
